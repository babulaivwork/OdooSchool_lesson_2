<odoo>
    <record id="disease_flu" model="odoo.school.hr.hospital.disease">
        <field name="name">Грип</field>
        <field name="code">FLU</field>
        <field name="description">Гостре респіраторне вірусне захворювання.</field>
    </record>

    <record id="disease_allergy" model="odoo.school.hr.hospital.disease">
        <field name="name">Алергія</field>
        <field name="code">ALG</field>
        <field name="description">Підвищена чутливість організму до алергенів.</field>
    </record>

    <record id="disease_bronchitis" model="odoo.school.hr.hospital.disease">
        <field name="name">Бронхіт</field>
        <field name="code">BRN</field>
        <field name="description">Запальне захворювання бронхів.</field>
    </record>
</odoo>
